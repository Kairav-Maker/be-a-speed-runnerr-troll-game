><next><block type="gameSplash" id="_y~hUO#a:O7Bipc-7{j]"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="Dx+.IjoT4dmHTG2sr[6F"><field name="TEXT">Hi,Welcome to my GAME</field></shadow></value><value name="subtitle"><shadow type="text" id="3-vm3~%%P*N~0?`c;S]U"><field name="TEXT"></field></shadow></value><next><block type="gameSplash" id="v_MX@QJajNlgd)On3`uI"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id=")]I~G4eMNO/-kh8*@Cr*"><field name="TEXT">Let me tell you about this game </field></shadow></value><value name="subtitle"><shadow type="text" id="@Rc!oH5B3(N;_tx.h0s:"><field name="TEXT"></field></shadow></value><next><block type="gameSplash" id="*i)|vGZX$hxIw-)w*m3/"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="-TeqP}7ct[@7}uAsdw8V"><field name="TEXT">Here you can speed run in a huge tilemap</field></shadow></value><value name="subtitle"><shadow type="text" id="E]WA5;k-KinI$AZJ5Ygo"><field name="TEXT"></field></shadow></value><next><block type="gameSplash" id="=W:{zM?szCN]b:BY,5Dl"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="/-HwmW$+pCY[fQB:A}7N"><field name="TEXT">This game is only for speed run no obejective</field></shadow></value><value name="subtitle"><shadow type="text" id="_C`oxGz`P/RF3M28ercH"><field name="TEXT"></field></shadow></value><next><block type="gameSplash" id="`d=8Rp$V%L7((:!SH_l{"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="6m@zhZ;`!DGzNW(sJA3R"><field name="TEXT">You can make your HIGH SCORESS </field></shadow></value><value name="subtitle"><shadow type="text" id="*4OvL3L$D8cso0=0n~L6"><field name="TEXT"></field></shadow></value><next><block type="gameSplash" id="k?|APB4(H6stJaPxB$$B"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="e;u.lE!w^-i[LA5R[S)N"><field name="TEXT">And if you are playing on laptop or computer,for jump you only have to press space </field></shadow></value><value name="subtitle"><shadow type="text" id="FG|6UfZVQ6z?M66M,:-u"><field name="TEXT"></field></shadow></value><next><block type="gameSplash" id="z^.mBfR)r:*rdJ8/-mTY"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="WpBt!c1v7kw`Hw[*bPtT"><field name="TEXT">My high score is 43 secs let's see who can beat this</field></shadow></value><value name="subtitle"><shadow type="text" id="JslLasnaj!V;*wBz@aNp"><field name="TEXT"></field></shadow></value><next><block type="gameSplash" id="]K]qklDv7k~ad${MlfmS"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id=".OkRBKGbMAF+WKd|g7@-"><field name="TEXT">And if you don't know why this is a troll game,YOU WILL SEE or not because you are a</field></shadow></value><value name="subtitle"><shadow type="text" id="X5|EdMb*Vt{Qn:8JRJ|9"><field name="TEXT"></field></shadow></value><next><block type="gameSplash" id="TxmQ$vInTmDW:2n8zG%~"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="oYUsFMKjrY]oM,#,MxHP"><field name="TEXT">PRO</field></shadow></value><value name="subtitle"><shadow type="text" id="Ja+6?Td}}#IS6ANZG99I"><field name="TEXT"></field></shadow></value><next><block type="music_stop_all_sounds" id="mTDScj]CLu%ZA]%S:3Kn"></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>