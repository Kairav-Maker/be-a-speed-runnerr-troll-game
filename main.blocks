le"><shadow type="text" id="*vmnqs8tt|66pHR+Skt."><field name="TEXT"></field></shadow></value><next><block type="gameSplash" id="gsC,s9r.]TWGw3uA?]$j"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="O#bo(btB_3IV2Ry9rD|3"><field name="TEXT">PRO</field></shadow></value><value name="subtitle"><shadow type="text" id="#{n{l#B/Pn4PwdS=-GyG"><field name="TEXT"></field></shadow></value><next><block type="music_stop_all_sounds" id="W{j+?{6$(33f;[C}]%Uv"></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>